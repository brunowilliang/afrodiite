{
  "name": "afrodiite",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build && tsc --noEmit",
    "start": "node .output/server/index.mjs",
    "check-types": "tsc --noEmit",
    "db:push": "drizzle-kit push --config=src/api/drizzle.config.ts",
    "db:pull": "drizzle-kit pull --config=src/api/drizzle.config.ts",
    "db:studio": "drizzle-kit studio --config=src/api/drizzle.config.ts",
    "db:generate": "drizzle-kit generate --config=src/api/drizzle.config.ts",
    "db:migrate": "drizzle-kit migrate --config=src/api/drizzle.config.ts",
    "db:seed": "bun run src/api/db/seed.ts",
    "db:seed:reset": "bun run src/api/db/reset.ts",
    "auth:gen": "@better-auth/cli@latest generate --output src/api/db/schemas/auth.ts --config src/lib/auth/auth.server.ts --yes",
    "npx:auth:gen": "npx @better-auth/cli@latest generate --config src/lib/auth/auth.server.ts --output src/api/db/schemas/auth.ts --yes",
    "email:dev": "email dev --dir src/lib/email/templates",
    "email:test": "TEST_TO=$TEST_TO bun run scripts/send-test-email.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.879.0",
    "@aws-sdk/s3-request-presigner": "^3.879.0",
    "@better-auth/stripe": "^1.3.7",
    "@bwg-labs/drizzle-crud": "0.2.1",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/modifiers": "^9.0.0",
    "@dnd-kit/sortable": "^10.0.0",
    "@heroui/react": "^2.8.2",
    "@hookform/resolvers": "^5.2.1",
    "@libsql/client": "^0.15.14",
    "@orpc/client": "^1.8.5",
    "@orpc/server": "^1.8.5",
    "@orpc/tanstack-query": "^1.8.5",
    "@paralleldrive/cuid2": "^2.2.2",
    "@react-aria/i18n": "^3.12.12",
    "@react-email/components": "^0.5.1",
    "@tailwindcss/postcss": "^4.1.12",
    "@tanstack/react-form": "^1.19.2",
    "@tanstack/react-query": "^5.85.5",
    "@tanstack/react-router": "^1.131.28",
    "@tanstack/react-router-devtools": "^1.131.28",
    "@tanstack/react-start": "^1.131.28",
    "@vercel/functions": "^3.1.0",
    "better-auth": "^1.3.7",
    "better-upload": "^1.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.4",
    "drizzle-orm": "^0.44.5",
    "drizzle-seed": "^0.3.1",
    "drizzle-zod": "^0.8.3",
    "embla-carousel-react": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "heroui-cli": "^1.2.3",
    "i18next": "^25.4.2",
    "motion": "^12.23.12",
    "next-themes": "^0.4.6",
    "postcss": "^8.5.6",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.62.0",
    "react-i18next": "^15.7.2",
    "react-phone-number-input": "^3.4.12",
    "react-photo-view": "^1.2.7",
    "resend": "^6.0.1",
    "slugify": "^1.6.6",
    "stripe": "^18.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.12",
    "use-styled": "^1.1.2",
    "zod": "^4.1.3"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.3.7",
    "@biomejs/biome": "^2.2.2",
    "@faker-js/faker": "^10.0.0",
    "@react-email/preview-server": "4.2.8",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.11",
    "@types/react-dom": "^19.1.8",
    "@vitejs/plugin-react": "^5.0.1",
    "autoprefixer": "^10.4.21",
    "react-email": "4.2.8",
    "tw-animate-css": "^1.3.7",
    "typescript": "^5.9.2",
    "vite": "^7.1.3",
    "vite-tsconfig-paths": "^5.1.4"
  }
}